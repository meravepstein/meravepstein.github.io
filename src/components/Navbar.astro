---
import MeravGif from "../assets/logo.gif";

interface Props {
  pageTitle: string;
}

const { pageTitle } = Astro.props;
---

<div
  class="sm:hidden z-[60] flex flex-row fixed top-0 left-0 bg-[#F9F9F9] w-screen items-center px-4 h-20"
>
  <div class="flex justify-center items-center">
    <button
      id="menuToggle"
      class="relative z-[70] w-12 h-12 flex flex-col justify-center items-center group cursor-pointer"
      aria-label="Toggle Menu"
    >
      <span
        class="line-top w-8 h-1 bg-black transition-all duration-300 ease-in-out mb-1.5"
      ></span>
      <span
        class="line-mid w-8 h-1 bg-black transition-all duration-300 ease-in-out mb-1.5"
      ></span>
      <span
        class="line-bot w-8 h-1 bg-black transition-all duration-300 ease-in-out"
      ></span>
    </button>
  </div>
  <div class="flex items-center justify-center mx-auto">
    <img src={MeravGif.src} class="max-h-16 w-auto" />
  </div>
</div>

<aside
  id="sideNav"
  class="fixed inset-y-0 left-0 z-50 w-full bg-[#F9F9F9] transform -translate-x-full transition-transform duration-300 ease-in-out
         sm:translate-x-0 sm:static sm:w-auto sm:h-full sm:ml-4 sm:bg-transparent overflow-y-auto"
>
  <ul
    class="flex flex-col gap-1 text-center pt-24 sm:pt-0 justify-between min-h-screen py-20"
  >
    <div class="flex flex-col gap-1">
      <li id="hero" class="list-none flex justify-center items-center sm:ml-12">
        <a href="/"><img src={MeravGif.src} class="max-h-56 w-auto" /></a>
      </li>

      {
        [
          { title: "ANIMATION", path: "/animation/", key: "animation" },
          { title: "EDITING", path: "/editing/", key: "editing" },
          {
            title: "STORYBOARDING",
            path: "/storyboarding/",
            key: "storyboarding",
          },
          {
            title: "CHARACTER/PROP DESIGN",
            path: "/character_prop_design/",
            key: "character/prop design",
          },
          {
            title: "PAINTINGS & BACKGROUNDS",
            path: "/paintings_backgrounds/",
            key: "paintings & backgrounds",
          },
          { title: "SKETCHBOOK", path: "/sketchbook/", key: "sketchbook" },
          {
            title: "STAINED GLASS",
            path: "/stained_glass/",
            key: "stained_glass",
          },
        ].map((link) => (
          <li
            class:list={[
              { "font-bold underline": pageTitle === link.key },
              "list-none text-xl py-2 sm:py-0",
            ]}
          >
            <a href={link.path}>{link.title}</a>
          </li>
        ))
      }
    </div>

    <div class="flex flex-col gap-1">
      <li
        class:list={[
          { "font-bold underline": pageTitle === "about" },
          "list-none text-xl py-2 sm:py-0",
        ]}
      >
        <a href="/">ABOUT</a>
      </li>
      <li
        class:list={[
          { "font-bold underline": pageTitle === "contact" },
          "list-none text-xl py-2 sm:py-0",
        ]}
      >
        <a href="/contact/">CONTACT</a>
      </li>
      <li class="list-none text-xl py-2 sm:py-0">
        <a href="/CV.pdf">CV</a>
      </li>
    </div>
  </ul>
</aside>

<script>
  const menuToggle = document.querySelector("#menuToggle");
  const sideNav = document.querySelector("#sideNav");

  menuToggle?.addEventListener("click", () => {
    const isActive = menuToggle.classList.toggle("is-active");

    if (isActive) {
      sideNav?.classList.remove("-translate-x-full");
      // Prevent body scroll when menu is open
      document.body.style.overflow = "hidden";
    } else {
      sideNav?.classList.add("-translate-x-full");
      document.body.style.overflow = "";
    }
  });
</script>

<style>
  /* Hamburger Animation */
  .is-active .line-top {
    transform: translateY(10px) rotate(45deg);
  }
  .is-active .line-mid {
    opacity: 0;
    transform: translateX(-20px);
  }
  .is-active .line-bot {
    transform: translateY(-10px) rotate(-45deg);
  }
</style>
