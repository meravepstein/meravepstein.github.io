---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/stained:glass/*.{png,gif}",
);

const imageModules = await Promise.all(
  Object.entries(images).map(async ([path, resolver]) => {
    const mod = await resolver();
    const filename = path.split("/").pop()?.split(".")[0] || "";
    const seriesId = filename.split("-")[0];
    return { src: mod.default, seriesId, filename };
  }),
);

const groupedImages = imageModules.reduce(
  (acc, img) => {
    if (!acc[img.seriesId]) acc[img.seriesId] = [];
    acc[img.seriesId].push(img);
    return acc;
  },
  {} as Record<string, typeof imageModules>,
);
---

<Layout pageTitle="stained glass">
  <div class="mx-auto p-8 sm:columns-1 md:columns-2 lg:columns-3">
    {
      Object.entries(groupedImages).map(([seriesId, group]) => (
        <div
          class="cursor-pointer flex items-center justify-center"
          onclick={`openModal(${JSON.stringify(group)}, 0)`}
        >
          <Image
            src={group[0].src}
            alt="Stained glass"
            class="mb-4 rounded-sm border border-transparent hover:border-gray-300 hover:shadow-lg transition-all duration-300 ease-in-out"
          />
        </div>
      ))
    }
  </div>

  <!-- Modal with raw SVG icons -->
  <div id="myModal" class="hidden fixed inset-0 z-50">
    <!-- Background -->
    <div class="absolute inset-0 bg-black/90" onclick="closeModal()"></div>

    <!-- Content -->
    <div
      class="relative z-10 w-full h-full flex items-center justify-center pointer-events-none"
    >
      <!-- Close button -->
      <button
        id="closeBtn"
        class="absolute top-5 right-5 text-white hover:text-gray-300 pointer-events-auto"
        style="z-index: 9999;"
      >
        <!-- X icon SVG -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="48"
          height="48"
          fill="currentColor"
          viewBox="0 0 256 256"
        >
          <path
            d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"
          ></path>
        </svg>
      </button>

      <!-- Previous button -->
      <button
        id="prevBtn"
        class="absolute left-5 text-white hover:text-gray-300 pointer-events-auto"
        style="z-index: 9999;"
      >
        <!-- CaretLeft icon SVG -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="48"
          height="48"
          fill="currentColor"
          viewBox="0 0 256 256"
        >
          <path
            d="M165.66,202.34a8,8,0,0,1-11.32,11.32l-80-80a8,8,0,0,1,0-11.32l80-80a8,8,0,0,1,11.32,11.32L91.31,128Z"
          ></path>
        </svg>
      </button>

      <!-- Image container -->
      <div id="modalImageContainer" class="pointer-events-auto"></div>

      <!-- Next button -->
      <button
        id="nextBtn"
        class="absolute right-5 text-white hover:text-gray-300 pointer-events-auto"
        style="z-index: 9999;"
      >
        <!-- CaretRight icon SVG -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="48"
          height="48"
          fill="currentColor"
          viewBox="0 0 256 256"
        >
          <path
            d="M181.66,133.66l-80,80A8,8,0,0,1,90.34,202.34L154.34,128,90.34,61.66A8,8,0,0,1,101.66,50.34l80,80A8,8,0,0,1,181.66,133.66Z"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</Layout>

<script is:inline>
  let currentGallery = [];
  let currentIndex = 0;

  function openModal(group, index) {
    currentGallery = group;
    currentIndex = index;
    updateModal();
    document.getElementById("myModal").classList.remove("hidden");
  }

  function updateModal() {
    const container = document.getElementById("modalImageContainer");
    container.innerHTML = `<img src="${currentGallery[currentIndex].src.src}" class="max-h-[80vh] max-w-[80vw] object-contain" />`;
  }

  function closeModal() {
    document.getElementById("myModal").classList.add("hidden");
  }

  document.getElementById("prevBtn").addEventListener("click", (e) => {
    e.stopPropagation();
    currentIndex =
      (currentIndex - 1 + currentGallery.length) % currentGallery.length;
    updateModal();
  });

  document.getElementById("nextBtn").addEventListener("click", (e) => {
    e.stopPropagation();
    currentIndex = (currentIndex + 1) % currentGallery.length;
    updateModal();
  });

  document.getElementById("closeBtn").addEventListener("click", (e) => {
    e.stopPropagation();
    closeModal();
  });

  // Keyboard navigation
  document.addEventListener("keydown", (e) => {
    const modal = document.getElementById("myModal");
    if (modal.classList.contains("hidden")) return;
    if (e.key === "Escape") closeModal();
    if (e.key === "ArrowLeft") document.getElementById("prevBtn").click();
    if (e.key === "ArrowRight") document.getElementById("nextBtn").click();
  });
</script>
