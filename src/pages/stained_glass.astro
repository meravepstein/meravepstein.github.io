---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

// Reverted to the colon path from your original code
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/stained:glass/*.{png,gif}",
);

const imageModules = await Promise.all(
  Object.entries(images).map(async ([path, resolver]) => {
    const mod = await resolver();
    const filename = path.split("/").pop()?.split(".")[0] || "";
    const seriesId = filename.split("-")[0];
    return { src: mod.default, seriesId, filename };
  }),
);

const groupedImages = imageModules.reduce(
  (acc, img) => {
    if (!acc[img.seriesId]) acc[img.seriesId] = [];
    acc[img.seriesId].push(img);
    return acc;
  },
  {} as Record<string, typeof imageModules>,
);

const groupedEntries = Object.entries(groupedImages);

// Distribute items into 3 columns to maintain Left-to-Right order
const columns: [string, any][][] = [[], [], []];
groupedEntries.forEach((entry, index) => {
  columns[index % 3].push(entry);
});
---

<Layout pageTitle="stained glass">
  <div class="mx-auto p-8 flex flex-row gap-6 items-start">
    {
      columns.map((column) => (
        <div class="flex flex-col gap-6 flex-1">
          {column.map(([seriesId, group], rowIdx) => (
            <div
              /* Only add 'group' class if there is more than one image */
              class:list={[
                "gallery-card relative bg-white border border-transparent transition-all duration-300",
                { "group hover:border-gray-200": group.length > 1 }
              ]}
              data-images={JSON.stringify(group.map((img) => img.src.src))}
            >
              <div class="relative overflow-hidden">
                {/* Main Image */}
                <Image
                  src={group[0].src}
                  alt="Stained glass"
                  class="main-display-image w-full h-auto block hover:shadow-lg transition-all ease-in-out duration-150"
                  format="webp"
                  quality={50}
                  loading={rowIdx === 0 ? "eager" : "lazy"}
                />

                {/* Hover Overlay - Only renders if group.length > 1 */}
                {group.length > 1 && (
                  <div class="absolute inset-0 flex flex-col justify-end opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-gradient-to-t from-black/10 to-transparent pointer-events-none">

                    {/* Navigation Arrows */}
                    <div class="flex justify-center gap-2 mb-2 pointer-events-auto">
                      <button class="prev-btn bg-white/90 p-1 hover:bg-white shadow-sm border border-gray-200">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256">
                          <path d="M165.66,202.34a8,8,0,0,1-11.32,11.32l-80-80a8,8,0,0,1,0-11.32l80-80a8,8,0,0,1,11.32,11.32L91.31,128Z" />
                        </svg>
                      </button>
                      <button class="next-btn bg-white/90 p-1 hover:bg-white shadow-sm border border-gray-200">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 256 256">
                          {/* Uniform mirrored path */}
                          <path d="M181.66,133.66l-80,80a8,8,0,0,1-11.32-11.32L154.34,128,90.34,61.66a8,8,0,0,1,11.32-11.32l80,80A8,8,0,0,1,181.66,133.66Z" />
                        </svg>
                      </button>
                    </div>

                    {/* Thumbnails Row */}
                    <div class="thumbnail-container flex justify-center gap-1 p-2 bg-white/90 backdrop-blur-sm pointer-events-auto overflow-x-auto border-t border-gray-100">
                      {group.map((img, idx) => (
                        <div
                          data-index={idx}
                          class={`thumb-item w-10 h-10 flex-shrink-0 cursor-pointer border-b-2 transition-all ${idx === 0 ? "border-black" : "border-transparent opacity-60 hover:opacity-100"}`}
                        >
                          <Image src={img.src} alt="Stained glass" class="w-full h-full object-cover" format="webp" quality={30} />
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      ))
    }
  </div>
</Layout>

<style>
  /* Hide scrollbar for thumbnail row */
  .thumbnail-container {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .thumbnail-container::-webkit-scrollbar {
    display: none;
  }

  /* Responsive adjustment: stack columns on mobile */
  @media (max-width: 768px) {
    .mx-auto {
      flex-direction: column;
    }
  }
</style>

<script is:inline>
  // Use DOMContentLoaded to ensure elements exist before script runs
  document.addEventListener("DOMContentLoaded", () => {
    const cards = document.querySelectorAll(".gallery-card");

    cards.forEach((card) => {
      const images = JSON.parse(card.dataset.images);
      const mainImg = card.querySelector(".main-display-image");
      const prevBtn = card.querySelector(".prev-btn");
      const nextBtn = card.querySelector(".next-btn");
      const thumbs = card.querySelectorAll(".thumb-item");

      let currentIndex = 0;

      function updateGallery(index) {
        currentIndex = index;
        if (mainImg) mainImg.src = images[currentIndex];

        thumbs.forEach((thumb, i) => {
          if (i === currentIndex) {
            thumb.classList.add("border-black");
            thumb.classList.remove("border-transparent", "opacity-60");
          } else {
            thumb.classList.remove("border-black");
            thumb.classList.add("border-transparent", "opacity-60");
          }
        });
      }

      prevBtn?.addEventListener("click", () => {
        const newIndex = (currentIndex - 1 + images.length) % images.length;
        updateGallery(newIndex);
      });

      nextBtn?.addEventListener("click", () => {
        const newIndex = (currentIndex + 1) % images.length;
        updateGallery(newIndex);
      });

      thumbs.forEach((thumb, i) => {
        thumb.addEventListener("mouseenter", () => updateGallery(i));
        thumb.addEventListener("click", () => updateGallery(i));
      });
    });
  });
</script>

<style>
  .thumbnail-container {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .thumbnail-container::-webkit-scrollbar {
    display: none;
  }
  .gallery-card {
    break-inside: avoid;
  }
</style>
